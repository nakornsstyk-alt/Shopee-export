{
  "manifest_version": 3,
  "name": "Order Exporter — Multi-Platform",
  "version": "1.1.0",
  "description": "Auto-export orders from Shopee, Lazada and more across all your brand windows",
  "permissions": [
    "tabs",
    "scripting",
    "alarms",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "https://seller.shopee.co.th/*",
    "https://sellercenter.lazada.co.th/*",
    "https://sellercenter.lazada.sg/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://seller.shopee.co.th/*"],
      "js": ["content/shopee.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://sellercenter.lazada.co.th/*",
        "https://sellercenter.lazada.sg/*"
      ],
      "js": ["content/lazada.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
